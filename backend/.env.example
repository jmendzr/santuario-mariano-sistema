# ============================================
# CONFIGURACIÓN DEL SISTEMA PARROQUIAL
# Renombrar este archivo a .env
# ============================================

# ── Base de datos PostgreSQL / Supabase ──────
# Si usas Supabase, copia la "Connection string" desde:
# Supabase Dashboard → Settings → Database → Connection string (modo "URI")
# Ejemplo: postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# (Alternativa: variables individuales para conexión local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=parroquia_db
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ── JWT Secret (cámbialo por algo seguro) ────
JWT_SECRET=parroquia_san_jose_secret_2025_cambiar_en_produccion
JWT_EXPIRES_IN=8h

# ── Puerto del servidor ──────────────────────
PORT=3000

# ── API Inti — Consulta DNI ──────────────────
# 1. Regístrate en https://app.apiinti.dev
# 2. Crea una API Key desde el Dashboard
# 3. Pega tu clave aquí (formato: inti_live_xxxx)
APIINTI_KEY=inti_live_TU_API_KEY_AQUI

# ── Almacenamiento de archivos ───────────────
STORAGE_TYPE=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── Entorno ──────────────────────────────────
NODE_ENV=production
# URL del frontend desplegado (Render, Netlify, etc.)
FRONTEND_URL=https://tu-frontend.netlify.app
